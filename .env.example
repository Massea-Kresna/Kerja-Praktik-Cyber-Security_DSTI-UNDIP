# ==============================================================================
# KONFIGURASI PENTEST PIPELINE DSTI UNDIP
# ==============================================================================

# Target utama scan
TARGET_DOMAIN=undip.ac.id

# Mode eksekusi (Opsional)
MAX_CONCURRENT=50

# ------------------------------------------------------------------------------
# SUPABASE REST API (UNTUK MENYIMPAN HASIL SCAN - db_manager.py)
# ------------------------------------------------------------------------------
# Dapatkan di Supabase Dashboard -> Project Settings -> API
# URL berformat: https://[PROJECT_REF].supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Gunakan "service_role" secret key agar bisa bypass RLS jika diperlukan, 
# atau "anon" public key tergantung konfigurasi keamanan Anda.
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# ------------------------------------------------------------------------------
# PENTEST-TOOLS API (UNTUK SCHEDULER - pentest_tools_scheduler.py)
# ------------------------------------------------------------------------------
# Dapatkan di akun Pentest-Tools Anda
PENTEST_TOOLS_API_KEY=YOUR_API_KEY_HERE

# ------------------------------------------------------------------------------
# SUPABASE POSTGRESQL DIRECT CONNECTION (OPSIONAL - scheduler_db.py)
# ------------------------------------------------------------------------------
# Digunakan oleh scheduler untuk menjadwalkan scan.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Jika tidak memakai SUPABASE_DB_URL, bisa menggunakan konfigurasi PostgreSQL manual:
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=postgres
